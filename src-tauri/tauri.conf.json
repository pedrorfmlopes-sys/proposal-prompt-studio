{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proposal Prompt Studio",
  "version": "0.2.0",
  "identifier": "com.proposalpromptstudio.app",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Proposal Prompt Studio",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
